---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';

const lang = 'zh';

const directions = [
  {
    href: '/zh/unity',
    title: 'Unity 游戏开发',
    desc: '互动体验与游戏创作',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v6c0 1.243 1.007 2.25 2.25 2.25h9a2.25 2.25 0 002.25-2.25V6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087V4.5a2.25 2.25 0 00-2.25-2.25h-4.5A2.25 2.25 0 005.25 4.5v1.587"/></svg>`,
    color: 'bg-blue-500',
  },
  {
    href: '/zh/uiux',
    title: 'UI/UX 设计',
    desc: '用户界面与体验设计',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
    color: 'bg-purple-500',
  },
  {
    href: '/zh/aigc',
    title: 'AIGC 生成',
    desc: 'AI 驱动的创意内容',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/></svg>`,
    color: 'bg-amber-500',
  },
];
---

<Base lang={lang} title={site.name[lang]}>
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center justify-center text-center px-6 sm:px-8 lg:px-16 overflow-hidden">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-blue-50 rounded-full blur-3xl opacity-50"></div>
      <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-purple-50 rounded-full blur-3xl opacity-50"></div>
    </div>

    <div class="animate-fade-in-up py-12 sm:py-16">
      <p class="text-xs sm:text-sm font-medium text-[var(--color-primary)] tracking-[0.2em] uppercase mb-4 sm:mb-5">Portfolio</p>
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-[6.5rem] font-bold mb-4 sm:mb-5 tracking-tight">
        <span class="gradient-text">{site.name[lang]}</span>
      </h1>
      <p class="text-lg sm:text-xl md:text-2xl text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
        {site.tagline[lang]}
      </p>
    </div>
  </section>

  <!-- 方向入口卡片 - 全宽 -->
  <section class="px-6 sm:px-8 lg:px-16 pb-16 sm:pb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
      {directions.map((d, i) => (
        <a
          href={d.href}
          class={`group relative flex flex-col p-6 sm:p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] hover:bg-white hover:border-[var(--color-primary)] hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-300 animate-fade-in-up animate-delay-${(i + 1) * 100}`}
        >
          <div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl ${d.color} text-white mb-5 group-hover:scale-110 transition-transform duration-300`}>
            <Fragment set:html={d.icon} />
          </div>
          <h2 class="text-lg sm:text-xl font-semibold mb-2 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">
            {d.title}
          </h2>
          <p class="text-sm sm:text-base text-[var(--color-text-muted)] leading-relaxed flex-1">{d.desc}</p>
          <div class="mt-5 flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity">
            <span>查看详情</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
