---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';

const lang = 'zh';

const directions = [
  {
    href: '/zh/unity',
    title: 'Unity 游戏开发',
    desc: '互动体验与游戏创作',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v6c0 1.243 1.007 2.25 2.25 2.25h9a2.25 2.25 0 002.25-2.25V6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087V4.5a2.25 2.25 0 00-2.25-2.25h-4.5A2.25 2.25 0 005.25 4.5v1.587"/></svg>`,
    gradient: 'from-blue-500 to-cyan-400',
    bgGradient: 'from-blue-50 to-cyan-50',
  },
  {
    href: '/zh/uiux',
    title: 'UI/UX 设计',
    desc: '用户界面与体验设计',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
    gradient: 'from-purple-500 to-pink-400',
    bgGradient: 'from-purple-50 to-pink-50',
  },
  {
    href: '/zh/aigc',
    title: 'AIGC 生成',
    desc: 'AI 驱动的创意内容',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/></svg>`,
    gradient: 'from-amber-500 to-orange-400',
    bgGradient: 'from-amber-50 to-orange-50',
  },
];
---

<Base lang={lang} title={site.name[lang]}>
  <!-- Hero Section -->
  <section class="relative min-h-[85vh] sm:min-h-[90vh] flex flex-col items-center justify-center text-center px-4 sm:px-6 overflow-hidden">
    <!-- 背景装饰 -->
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute top-1/4 left-1/4 w-64 h-64 sm:w-96 sm:h-96 bg-[var(--color-primary-50)] rounded-full blur-3xl opacity-60"></div>
      <div class="absolute bottom-1/4 right-1/4 w-48 h-48 sm:w-80 sm:h-80 bg-purple-50 rounded-full blur-3xl opacity-60"></div>
    </div>

    <div class="animate-fade-in-up">
      <p class="text-xs sm:text-sm font-medium text-[var(--color-primary)] tracking-widest uppercase mb-4 sm:mb-6">Portfolio</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold mb-4 sm:mb-6 md:mb-8 tracking-tight">
        <span class="gradient-text">{site.name[lang]}</span>
      </h1>
      <p class="text-base sm:text-xl md:text-2xl text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
        {site.tagline[lang]}
      </p>
    </div>

    <!-- 向下滚动指示 -->
    <div class="absolute bottom-12 animate-bounce">
      <svg class="w-6 h-6 text-[var(--color-text-light)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- 方向入口 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 sm:pb-24">
    <div class="text-center mb-12">
      <p class="text-sm text-[var(--color-text-muted)] tracking-wide">探索我的作品</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {directions.map((d, i) => (
        <a
          href={d.href}
          class={`group relative block p-8 rounded-2xl border border-[var(--color-border)] bg-white card-hover animate-fade-in-up animate-delay-${(i + 1) * 100}`}
        >
          <!-- 图标 -->
          <div class={`inline-flex items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-br ${d.gradient} text-white mb-6 group-hover:scale-110 transition-transform duration-300`}>
            <Fragment set:html={d.icon} />
          </div>
          <h2 class="text-xl font-semibold mb-2 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">
            {d.title}
          </h2>
          <p class="text-[var(--color-text-muted)] leading-relaxed">{d.desc}</p>
          <!-- 箭头 -->
          <div class="absolute top-8 right-8 text-[var(--color-text-light)] group-hover:text-[var(--color-primary)] group-hover:translate-x-1 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
