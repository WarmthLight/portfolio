---
import Base from '../../layouts/Base.astro';
import { ui } from '../../data/i18n';
import { getCollection } from 'astro:content';

const lang = 'zh';
const t = ui[lang];
const caseStudies = (await getCollection('caseStudies'))
  .filter(study => study.data.tags.includes('aigc'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base lang={lang} title="AIGC 生成 - 作品集">
  <section class="px-6 sm:px-8 lg:px-16 pt-16 sm:pt-24 pb-16 sm:pb-24">
    <div class="mb-12 text-center">
      <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase mb-3">{t.aigc.label}</p>
      <h1 class="text-4xl font-bold text-[var(--color-text)]">AIGC 生成</h1>
      <p class="text-[var(--color-text-muted)] mt-3 text-lg">探索AI在创意设计、视频制作、游戏开发中的应用</p>
    </div>

    {caseStudies.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {caseStudies.map((study) => (
          <a
            href={`/zh/aigc/${study.id}`}
            class="group block rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden hover:shadow-2xl hover:shadow-amber-500/10 hover:-translate-y-1 transition-all duration-500"
          >
            <div class="aspect-video bg-[var(--color-bg-alt)] overflow-hidden relative">
              <img
                src={study.data.cover}
                alt={study.data.title[lang]}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-black/20">
                <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
                  <svg class="w-6 h-6 text-[var(--color-primary)] ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-medium text-[var(--color-primary)] bg-[var(--color-primary-50)] px-2 py-0.5 rounded">{study.data.role[lang]}</span>
                <span class="text-xs text-[var(--color-text-light)]">{study.data.timeline}</span>
              </div>
              <h2 class="text-xl font-bold mb-2 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">{study.data.title[lang]}</h2>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">{study.data.subtitle[lang]}</p>
              <div class="flex flex-wrap gap-2">
                {study.data.tags.filter(tag => tag !== 'aigc').slice(0, 4).map(tag => (
                  <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] border border-[var(--color-border-light)]">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-32 rounded-3xl border border-dashed border-[var(--color-border)] bg-[var(--color-bg-alt)]">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-amber-500 via-orange-400 to-rose-400 text-white mb-6">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-[var(--color-text)] mb-3">{t.empty.title}</h2>
        <p class="text-[var(--color-text-muted)] text-lg">{t.empty.subtitle}</p>
      </div>
    )}
  </section>
</Base>
