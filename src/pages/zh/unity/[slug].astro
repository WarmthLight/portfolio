---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../../data/i18n';

const lang = 'zh';
const t = ui[lang];

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, cover, video, tags } = project.data;
---

<Base lang={lang} title={`${title[lang]} - 作品集`}>
  <article class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 sm:pt-24 pb-16 sm:pb-24">
    <!-- 返回按钮 -->
    <a href={`${import.meta.env.BASE_URL}zh/unity`} class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors mb-8 group">
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      {t.project.back}
    </a>

    <!-- 视频播放器 -->
    <div class="aspect-video rounded-2xl overflow-hidden bg-black mb-10 shadow-2xl">
      <video
        src={video}
        controls
        preload="metadata"
        class="w-full h-full"
        poster={cover}
      >
        Your browser does not support the video tag.
      </video>
    </div>

    <!-- 项目信息 -->
    <div class="max-w-3xl">
      <h1 class="text-4xl font-bold mb-4 text-[var(--color-text)]">{title[lang]}</h1>
      <p class="text-[var(--color-text-secondary)] text-lg leading-relaxed mb-8">{description[lang]}</p>

      <!-- 技术栈 -->
      <div class="p-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border-light)]">
        <h2 class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wide mb-4">{t.project.techStack}</h2>
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="tag bg-white text-[var(--color-text-secondary)] border border-[var(--color-border)]">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </article>
</Base>
