---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';
import { ui } from '../../data/i18n';

const lang = 'zh';
const t = ui[lang];

const skills = ['Unity', 'C#', 'C++', 'Figma', 'Adobe XD', 'Stable Diffusion', 'ComfyUI', 'Blender'];
---

<Base lang={lang} title="关于我 - 作品集">
  <section class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-16 pt-24 sm:pt-32 pb-16 sm:pb-24">
    <!-- 个人简介卡片 -->
    <div class="relative p-6 sm:p-8 md:p-12 rounded-2xl sm:rounded-3xl bg-gradient-to-br from-[var(--color-bg-alt)] to-white border border-[var(--color-border-light)] mb-12 sm:mb-16 overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] opacity-5 rounded-full -translate-y-1/2 translate-x-1/2"></div>

      <div class="relative flex flex-col md:flex-row items-center md:items-start gap-8 text-center md:text-left">
        <div class="w-28 h-28 rounded-2xl bg-white border-2 border-[var(--color-border)] flex items-center justify-center overflow-hidden shadow-lg flex-shrink-0">
          <img src="/images/avatar-placeholder.svg" alt={site.name[lang]} class="w-full h-full object-cover" />
        </div>
        <div>
          <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase mb-2">{t.about.title}</p>
          <h1 class="text-3xl font-bold text-[var(--color-text)] mb-3">{site.name[lang]}</h1>
          <p class="text-[var(--color-text-muted)] mb-4">{site.tagline[lang]}</p>
          <p class="text-[var(--color-text-secondary)] leading-relaxed">{t.about.bio}</p>
        </div>
      </div>
    </div>

    <!-- 技能 -->
    <div class="mb-16">
      <div class="text-center mb-8">
        <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase mb-3">{t.about.skills}</p>
        <h2 class="text-2xl font-bold text-[var(--color-text)]">{t.about.skills}</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {skills.map(skill => (
          <div class="p-4 rounded-xl bg-white border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-md transition-all text-center group">
            <span class="text-sm font-medium text-[var(--color-text-secondary)] group-hover:text-[var(--color-primary)] transition-colors">{skill}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- 联系方式 -->
    <div>
      <div class="text-center mb-8">
        <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase mb-3">{t.about.contact}</p>
        <h2 class="text-2xl font-bold text-[var(--color-text)]">{t.about.contact}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href={`mailto:${site.email}`} class="flex items-center gap-4 p-5 rounded-xl bg-white border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-md transition-all group">
          <div class="w-10 h-10 rounded-lg bg-[var(--color-primary-50)] flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg class="w-5 h-5 text-[var(--color-primary)] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">Email</p>
            <p class="text-sm text-[var(--color-text-secondary)] font-medium">{site.email}</p>
          </div>
        </a>
        <a href={site.github} target="_blank" rel="noopener" class="flex items-center gap-4 p-5 rounded-xl bg-white border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-md transition-all group">
          <div class="w-10 h-10 rounded-lg bg-[var(--color-primary-50)] flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg class="w-5 h-5 text-[var(--color-primary)] group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">GitHub</p>
            <p class="text-sm text-[var(--color-text-secondary)] font-medium truncate">{site.github.replace('https://github.com/', '')}</p>
          </div>
        </a>
        <div class="flex items-center gap-4 p-5 rounded-xl bg-white border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-md transition-all group cursor-default">
          <div class="w-10 h-10 rounded-lg bg-[var(--color-primary-50)] flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg class="w-5 h-5 text-[var(--color-primary)] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">WeChat</p>
            <p class="text-sm text-[var(--color-text-secondary)] font-medium">{site.wechat}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
