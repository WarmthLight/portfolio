---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../data/i18n';

const lang = 'en';
const t = ui[lang];

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Base lang={lang} title="Unity Dev - Portfolio">
  <section class="px-6 sm:px-8 lg:px-16 pt-16 sm:pt-24 pb-16 sm:pb-24">
    <div class="mb-12 text-center">
      <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase mb-3">{t.unity.label}</p>
      <h1 class="text-4xl font-bold text-[var(--color-text)]">Unity Game Development</h1>
    </div>
    {projects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {projects.map(project => (
          <ProjectCard project={project} lang={lang} basePath={`${import.meta.env.BASE_URL}en/unity`} />
        ))}
      </div>
    ) : (
      <div class="text-center py-24 rounded-2xl border border-dashed border-[var(--color-border)]">
        <div class="text-5xl mb-4">🎮</div>
        <p class="text-[var(--color-text-muted)] text-lg">{t.unity.empty}</p>
      </div>
    )}
  </section>
</Base>
