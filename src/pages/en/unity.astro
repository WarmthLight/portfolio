---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Base lang={lang} title="Unity Dev - Portfolio">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-12">
      <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase mb-3">Unity Development</p>
      <h1 class="text-4xl font-bold text-[var(--color-text)]">Unity Game Development</h1>
      <p class="text-[var(--color-text-muted)] mt-3 text-lg">Explore my interactive experiences and game projects</p>
    </div>
    {projects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map(project => (
          <ProjectCard project={project} lang={lang} basePath="/en/unity" />
        ))}
      </div>
    ) : (
      <div class="text-center py-24 rounded-2xl border border-dashed border-[var(--color-border)]">
        <div class="text-5xl mb-4">🎮</div>
        <p class="text-[var(--color-text-muted)] text-lg">No projects yet</p>
      </div>
    )}
  </section>
</Base>
