---
import Base from '../../layouts/Base.astro';
import { ui } from '../../data/i18n';
import { getCollection } from 'astro:content';

const lang = 'en';
const t = ui[lang];
const caseStudies = (await getCollection('caseStudies')).sort((a, b) => a.data.order - b.data.order);
---

<Base lang={lang} title="UI/UX Design - Portfolio">
  <section class="px-6 sm:px-8 lg:px-16 pt-16 sm:pt-24 pb-16 sm:pb-24">
    <div class="mb-12 text-center">
      <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase mb-3">{t.uiux.label}</p>
      <h1 class="text-4xl font-bold text-[var(--color-text)]">UI/UX Design</h1>
      <p class="text-[var(--color-text-muted)] mt-3 text-lg">Complete design cases from research to high-fidelity delivery</p>
    </div>

    {caseStudies.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {caseStudies.map((study) => (
          <a
            href={`/en/uiux/${study.id}`}
            class="group block rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden hover:shadow-2xl hover:shadow-blue-500/10 hover:-translate-y-1 transition-all duration-500"
          >
            <div class="aspect-video bg-[var(--color-bg-alt)] overflow-hidden relative">
              <img
                src={study.data.cover}
                alt={study.data.title[lang]}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-black/20">
                <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
                  <svg class="w-6 h-6 text-[var(--color-primary)] ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-medium text-[var(--color-primary)] bg-[var(--color-primary-50)] px-2 py-0.5 rounded">{study.data.role[lang]}</span>
                <span class="text-xs text-[var(--color-text-light)]">{study.data.timeline}</span>
              </div>
              <h2 class="text-xl font-bold mb-2 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">{study.data.title[lang]}</h2>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">{study.data.subtitle[lang]}</p>
              <div class="flex flex-wrap gap-2">
                {study.data.tags.slice(0, 4).map(tag => (
                  <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] border border-[var(--color-border-light)]">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-32 rounded-3xl border border-dashed border-[var(--color-border)] bg-[var(--color-bg-alt)]">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-violet-500 via-purple-400 to-fuchsia-400 text-white mb-6">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-[var(--color-text)] mb-3">{t.empty.title}</h2>
        <p class="text-[var(--color-text-muted)] text-lg">{t.empty.subtitle}</p>
      </div>
    )}
  </section>
</Base>
