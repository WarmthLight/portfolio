---
import Base from '../../layouts/Base.astro';
import { ui } from '../../data/i18n';

const lang = 'en';
const t = ui[lang];
---

<Base lang={lang} title="UI/UX Design - Portfolio">
  <section class="px-6 sm:px-8 lg:px-16 pt-24 sm:pt-32 pb-16 sm:pb-24">
    <div class="mb-12 text-center">
      <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase mb-3">{t.uiux.label}</p>
      <h1 class="text-4xl font-bold text-[var(--color-text)]">UI/UX Design</h1>
    </div>
    <div class="text-center py-32 rounded-3xl border border-dashed border-[var(--color-border)] bg-[var(--color-bg-alt)]">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-violet-500 via-purple-400 to-fuchsia-400 text-white mb-6">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/>
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-[var(--color-text)] mb-3">{t.empty.title}</h2>
      <p class="text-[var(--color-text-muted)] text-lg">{t.empty.subtitle}</p>
    </div>
  </section>
</Base>
