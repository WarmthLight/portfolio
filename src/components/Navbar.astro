---
import { site } from '../data/site';
import { ui } from '../data/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

const { lang } = Astro.props;
const t = ui[lang];
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `/${lang}/unity`, label: t.nav.unity },
  { href: `/${lang}/uiux`, label: t.nav.uiux },
  { href: `/${lang}/aigc`, label: t.nav.aigc },
  { href: `/${lang}/about`, label: t.nav.about },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 glass-nav" id="navbar">
  <div class="px-6 sm:px-8 lg:px-16 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={`/${lang}/`} class="flex items-center gap-2 group flex-shrink-0">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center">
        <span class="text-white text-sm font-bold">P</span>
      </div>
      <span class="text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors hidden sm:inline">
        {site.name[lang]}
      </span>
    </a>

    <!-- 桌面端导航 -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-3 py-1.5 rounded-lg text-sm transition-all ${
            currentPath.startsWith(link.href)
              ? 'text-[var(--color-primary)] bg-[var(--color-primary-50)] font-medium'
              : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-alt)]'
          }`}
        >
          {link.label}
        </a>
      ))}
      <div class="w-px h-5 bg-[var(--color-border)] mx-2"></div>
      <LanguageSwitcher lang={lang} currentPath={currentPath} />
    </div>

    <!-- 移动端汉堡按钮 -->
    <button
      id="menu-toggle"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg hover:bg-[var(--color-bg-alt)] transition-colors"
      aria-label="Toggle menu"
    >
      <svg id="menu-open" class="w-5 h-5 text-[var(--color-text)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="menu-close" class="w-5 h-5 text-[var(--color-text)] hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- 移动端菜单 -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border-light)] bg-white/95 backdrop-blur-xl">
    <div class="px-4 py-4 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block px-4 py-2.5 rounded-lg text-sm transition-all ${
            currentPath.startsWith(link.href)
              ? 'text-[var(--color-primary)] bg-[var(--color-primary-50)] font-medium'
              : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-alt)]'
          }`}
        >
          {link.label}
        </a>
      ))}
      <div class="px-4 pt-2">
        <LanguageSwitcher lang={lang} currentPath={currentPath} />
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open');
  const closeIcon = document.getElementById('menu-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // 点击链接后关闭菜单
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
