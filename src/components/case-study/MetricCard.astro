---
const { value, label } = Astro.props;
---

<div class="p-5 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border-light)] text-center card-hover">
  <div class="text-3xl font-bold gradient-text mb-2">{value}</div>
  <div class="text-sm text-[var(--color-text-muted)]">{label}</div>
</div>
